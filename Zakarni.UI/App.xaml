<Application
    x:Class="Zakarni.UI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary xmlns:converters="using:Zakarni.UI.Converters">
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="Styles/ModernStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters remain unchanged -->
            <converters:StrikeThroughConverter x:Key="StrikeThroughConverter"/>
            <converters:PriorityToBrushConverter x:Key="PriorityToBrushConverter"/>
            <converters:DateTimeToRelativeConverter x:Key="DateTimeToRelativeConverter"/>

            <!-- Styles mapped for legacy support until fully refactored -->
            <Style x:Key="SubtleButtonStyle" TargetType="Button"><Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/></Style>
            <Style x:Key="MajorCheckBoxStyle" TargetType="CheckBox"><Setter Property="MinWidth" Value="32"/><Setter Property="Padding" Value="0"/></Style>
            <Style x:Key="AppTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource PremiumHeaderStyle}" />
            <Style x:Key="AppSubtitleStyle" TargetType="TextBlock" BasedOn="{StaticResource PremiumSubheaderStyle}" />
            <Style x:Key="AppCaptionStyle" TargetType="TextBlock" BasedOn="{StaticResource PremiumBodyStyle}"><Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}"/></Style>
            <Style x:Key="ModernCardBorderStyle" TargetType="Border" BasedOn="{StaticResource PremiumCardStyle}"><Setter Property="Padding" Value="24"/></Style>
            <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource PremiumAccentButtonStyle}" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
