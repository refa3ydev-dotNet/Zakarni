<Window
    x:Class="Zakarni.UI.PrayerFloatingWidgetWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="Transparent" PointerPressed="OnPointerPressed" Padding="8">
        <!-- Floating Acrylic Pill -->
        <Border CornerRadius="16" 
                Background="{ThemeResource PremiumCardAcrylicBrush}" 
                BorderBrush="#20FFFFFF" 
                BorderThickness="1" 
                Padding="16,0"
                HorizontalAlignment="Stretch" 
                VerticalAlignment="Stretch">
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Icon -->
                    <ColumnDefinition Width="*"/>    <!-- Progress & Text -->
                    <ColumnDefinition Width="Auto"/> <!-- Time -->
                    <ColumnDefinition Width="Auto"/> <!-- Actions -->
                </Grid.ColumnDefinitions>

                <!-- Elegant Circular Icon -->
                <Border Width="32" Height="32" Background="{ThemeResource BrandAccentAlphaBrush}" BorderBrush="{ThemeResource BrandAccentBrush}" BorderThickness="1" CornerRadius="16" VerticalAlignment="Center" Margin="0,0,16,0">
                    <FontIcon Glyph="&#xE706;" FontSize="14" Foreground="{ThemeResource BrandAccentBrush}"/>
                </Border>

                <!-- Main Content -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0" Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                        <TextBlock Text="{x:Bind ViewModel.WidgetTitle, Mode=OneWay}" FontFamily="{StaticResource PrimaryFont}" FontWeight="SemiBold" FontSize="16" Foreground="{x:Bind ViewModel.WidgetTitleColor, Mode=OneWay}" Margin="0,0,0,-2"/>
                        <TextBlock Text="{x:Bind ViewModel.WidgetSubtitle, Mode=OneWay}" FontSize="10" Foreground="{ThemeResource TextSecondaryBrush}" Opacity="0.8" VerticalAlignment="Bottom" CharacterSpacing="50"/>
                    </StackPanel>
                    
                    <ProgressBar Value="{x:Bind ViewModel.HeroProgressValue, Mode=OneWay}" Maximum="{x:Bind ViewModel.HeroProgressMax, Mode=OneWay}" Foreground="{x:Bind ViewModel.WidgetProgressColor, Mode=OneWay}" Background="#1AFFFFFF" Height="2" CornerRadius="1" HorizontalAlignment="Stretch"/>
                </StackPanel>

                <!-- Countdown -->
                <TextBlock Grid.Column="2" Text="{x:Bind ViewModel.TimeRemaining, Mode=OneWay}" FontSize="20" FontWeight="SemiBold" Foreground="{x:Bind ViewModel.WidgetTitleColor, Mode=OneWay}" VerticalAlignment="Center" Margin="0,0,16,0" FontFamily="Consolas, Segoe UI"/>

                <!-- Actions -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Button Background="Transparent" BorderThickness="0" CornerRadius="14" Width="28" Height="28" Padding="0" Click="OnOpenMain" ToolTipService.ToolTip="Open Dashboard">
                        <FontIcon Glyph="&#xE8A7;" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}"/>
                    </Button>
                    <Button Background="Transparent" BorderThickness="0" CornerRadius="14" Width="28" Height="28" Padding="0" ToolTipService.ToolTip="Options">
                        <FontIcon Glyph="&#xE10C;" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}"/>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Open Dashboard" Command="{x:Bind ViewModel.ShowAppCommand}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE8A7;"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Mute Next Adhan" Command="{x:Bind ViewModel.MuteNextAdhanCommand}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE198;"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator/>
                                <MenuFlyoutItem Text="Exit Zakarni" Command="{x:Bind ViewModel.ExitAppCommand}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE106;"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>