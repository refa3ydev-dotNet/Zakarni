<Window
    x:Class="Zakarni.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tb="using:H.NotifyIcon"
    xmlns:models="using:Zakarni.Core.Models"
    xmlns:viewmodels="using:Zakarni.UI.ViewModels"
    Title="Zakarni">

    <!-- Global Grid holding Navigation and Content -->
    <Grid Background="Transparent">
        
        <!-- Main Navigation View -->
        <NavigationView x:Name="RootNavigationView" 
                        IsBackButtonVisible="Collapsed" 
                        ItemInvoked="OnNavigationItemInvoked"
                        Style="{StaticResource PremiumNavViewStyle}">
            
            <NavigationView.MenuItems>
                <NavigationViewItem x:Uid="NavDashboard" Tag="home" Content="Dashboard" Icon="Home" />
                <NavigationViewItem x:Uid="NavQuran" Tag="quran" Content="Quran" Icon="Library" />
                <NavigationViewItem x:Uid="NavTodo" Tag="todo" Content="Habits" Icon="Edit" />
                <NavigationViewItem x:Uid="NavAthkar" Tag="athkar" Content="Athkar" Icon="Favorite" />
            </NavigationView.MenuItems>

            <!-- Main Content Area -->
            <Grid x:Name="ContentRoot" Padding="40,24,40,40">
                
                <!-- ============================================== -->
                <!-- DASHBOARD VIEW                                 -->
                <!-- ============================================== -->
                <ScrollViewer x:Name="HomeView" Visibility="Visible">
                    <StackPanel Spacing="56" MaxWidth="1000" HorizontalAlignment="Stretch">
                        
                        <!-- Header Section -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Spacing="4">
                                <TextBlock Text="Assalamu Alaikum" Style="{StaticResource PremiumHeaderStyle}" FontSize="40"/>
                                <TextBlock Text="Peace and blessings be upon you" Style="{StaticResource PremiumSubheaderStyle}" Opacity="0.5"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Top" Margin="0,12,0,0">
                                <FontIcon Glyph="&#xE707;" Foreground="{ThemeResource BrandAccentBrush}" FontSize="16"/>
                                <TextBlock Text="{x:Bind ViewModel.LocationText, Mode=OneWay}" Style="{StaticResource PremiumBodyStyle}" Foreground="{ThemeResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>

                        <!-- Hero Section: Next Prayer (Deep Acrylic & Emerald) -->
                        <Border Background="{ThemeResource PremiumHeroAcrylicBrush}" 
                                BorderBrush="{ThemeResource BrandPrimaryBrush}" 
                                BorderThickness="0,0,0,2"
                                CornerRadius="24" 
                                Padding="56"
                                Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Circular Progress (Refined) -->
                                <Grid Width="220" Height="220">
                                    <ProgressRing Value="100" Maximum="100" Foreground="{ThemeResource SurfaceBackground}" Width="220" Height="220" IsIndeterminate="False" BorderThickness="8" Opacity="0.2"/>
                                    <ProgressRing Value="{x:Bind ViewModel.HeroProgressValue, Mode=OneWay}" Maximum="{x:Bind ViewModel.HeroProgressMax, Mode=OneWay}" Foreground="{ThemeResource BrandAccentBrush}" Width="220" Height="220" IsIndeterminate="False" BorderThickness="8"/>
                                    
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="4">
                                        <TextBlock Text="{x:Bind ViewModel.TimeRemaining, Mode=OneWay}" FontSize="40" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                        <TextBlock Text="REMAINING" FontSize="14" Foreground="{ThemeResource BrandAccentBrush}" HorizontalAlignment="Center" Opacity="0.8" CharacterSpacing="50"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Details -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="64,0,0,0" Spacing="16">
                                    <TextBlock Text="NEXT PRAYER" FontSize="14" Foreground="{ThemeResource BrandAccentBrush}" Opacity="0.9" CharacterSpacing="150"/>
                                    <TextBlock Text="{x:Bind ViewModel.NextPrayerName, Mode=OneWay}" FontSize="56" FontWeight="Bold" Foreground="White" Margin="0,-8,0,0"/>
                                    
                                    <Button Click="OnViewFullSchedule" Style="{StaticResource PremiumAccentButtonStyle}" Background="{ThemeResource BrandAccentBrush}" Foreground="{ThemeResource SurfaceBackground}" Margin="0,16,0,0" Padding="24,12" CornerRadius="20">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <FontIcon Glyph="&#xE163;" FontSize="14"/>
                                            <TextBlock Text="View Full Schedule" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Prayer Cards Grid (Luxurious Cards) -->
                        <StackPanel x:Name="TodayScheduleSection" Spacing="24">
                            <TextBlock Text="Today's Schedule" Style="{StaticResource PremiumSubheaderStyle}" FontSize="24"/>
                            
                            <ItemsControl ItemsSource="{x:Bind ViewModel.PrayerCards}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VariableSizedWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="5"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:PrayerCardViewModel">
                                        <!-- Active prayer gets Emerald glow/border, inactive gets dark acrylic -->
                                        <Border Width="160" Height="140" 
                                                Style="{StaticResource PremiumCardStyle}" 
                                                Background="{x:Bind Background, Mode=OneWay}" 
                                                BorderBrush="{x:Bind BorderBrush, Mode=OneWay}"
                                                BorderThickness="{x:Bind BorderThickness, Mode=OneWay}">
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                                                <TextBlock Text="{x:Bind Name}" FontSize="16" FontWeight="SemiBold" Foreground="{x:Bind Foreground, Mode=OneWay}" Opacity="0.7" HorizontalAlignment="Center" CharacterSpacing="50"/>
                                                <TextBlock Text="{x:Bind Time}" FontSize="28" FontWeight="Bold" Foreground="{x:Bind Foreground, Mode=OneWay}" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- ============================================== -->
                <!-- QURAN VIEW (Master/Detail Layout)              -->
                <!-- ============================================== -->
                <Grid x:Name="QuranView" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="380"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Left Pane: Surah List -->
                    <Border Style="{StaticResource PremiumCardStyle}" Margin="0,0,32,0" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Search & Header -->
                            <StackPanel Padding="24" Spacing="16">
                                <TextBlock Text="Surahs" Style="{StaticResource PremiumSubheaderStyle}"/>
                                <TextBox PlaceholderText="Search Surah..." CornerRadius="8" BorderThickness="0" Background="{ThemeResource SurfaceBackground}" Padding="12,8"/>
                            </StackPanel>

                            <!-- List -->
                            <ListView Grid.Row="1" ItemsSource="{x:Bind QuranVM.Surahs}" SelectedItem="{x:Bind QuranVM.SelectedSurah, Mode=TwoWay}" 
                                      Visibility="{x:Bind QuranVM.HasNoError, Mode=OneWay}" Padding="12">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:QuranSurah">
                                        <Grid Padding="12,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Surah Number Circle -->
                                            <Border Width="40" Height="40" CornerRadius="20" 
                                                    Background="{ThemeResource BrandAccentAlphaBrush}" 
                                                    BorderBrush="{ThemeResource BrandAccentBrush}" 
                                                    BorderThickness="1"
                                                    Margin="0,0,16,0">
                                                <TextBlock Text="{x:Bind Number}" 
                                                           Foreground="{ThemeResource BrandAccentBrush}" 
                                                           FontSize="14" 
                                                           FontWeight="SemiBold" 
                                                           HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind EnglishName}" Style="{StaticResource PremiumBodyStyle}" FontWeight="SemiBold" FontSize="16"/>
                                                <TextBlock Text="{x:Bind Name}" Style="{StaticResource QuranTextStyle}" FontSize="18" HorizontalAlignment="Left" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            
                            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12" Visibility="{x:Bind QuranVM.IsLoading, Mode=OneWay}">
                                <ProgressRing IsActive="True" Foreground="{ThemeResource BrandPrimaryBrush}"/>
                            </StackPanel>
                            <TextBlock Grid.Row="1" Text="{x:Bind QuranVM.ErrorMessage, Mode=OneWay}" Foreground="Red" TextWrapping="Wrap" Margin="24" Visibility="{x:Bind QuranVM.HasError, Mode=OneWay}"/>
                        </Grid>
                    </Border>

                    <!-- Right Pane: Reading Preview -->
                    <Border Grid.Column="1" Style="{StaticResource PremiumCardStyle}" Padding="48" Visibility="{x:Bind QuranVM.HasNoError, Mode=OneWay}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="48">
                            <FontIcon Glyph="&#xE8B1;" FontSize="80" Foreground="{ThemeResource BrandAccentBrush}" Opacity="0.3"/>
                            
                            <StackPanel Spacing="12" HorizontalAlignment="Center">
                                <TextBlock Text="{x:Bind QuranVM.SelectedSurahName, Mode=OneWay}" Style="{StaticResource QuranTextStyle}" FontSize="72" Foreground="{ThemeResource BrandPrimaryBrush}"/>
                                <TextBlock Text="{x:Bind QuranVM.SelectedSurah.EnglishName, Mode=OneWay}" Style="{StaticResource PremiumSubheaderStyle}" HorizontalAlignment="Center" Opacity="0.6"/>
                            </StackPanel>
                            
                            <Button Click="OnOpenReadingMode" Style="{StaticResource PremiumAccentButtonStyle}" HorizontalAlignment="Center" Margin="0,16,0,0" Padding="32,16" CornerRadius="24">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <FontIcon Glyph="&#xE736;" FontSize="16"/>
                                        <TextBlock Text="Read Surah" FontWeight="Bold"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ============================================== -->
                <!-- TODO / HABITS VIEW                             -->
                <!-- ============================================== -->
                <ScrollViewer x:Name="TodoView" Visibility="Collapsed">
                    <StackPanel Spacing="40" MaxWidth="800" HorizontalAlignment="Center">
                        <TextBlock Text="Spiritual Habits" Style="{StaticResource PremiumHeaderStyle}"/>
                        
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox PlaceholderText="Add a new habit or task..." Text="{x:Bind TodoVM.NewTaskText, Mode=TwoWay}" CornerRadius="12" Height="56" VerticalContentAlignment="Center" FontSize="16"/>
                            <Button Grid.Column="1" Command="{x:Bind TodoVM.AddTaskCommand}" Content="Add Habit" Style="{StaticResource PremiumAccentButtonStyle}" Height="56" CornerRadius="12" Padding="24,0"/>
                        </Grid>

                        <ItemsControl ItemsSource="{x:Bind TodoVM.Tasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:TodoItem">
                                    <Border Style="{StaticResource PremiumCardStyle}" Padding="24" Margin="0,0,0,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <CheckBox IsChecked="{x:Bind IsCompleted, Mode=TwoWay}" MinWidth="32">
                                                <CheckBox.RenderTransform>
                                                    <ScaleTransform ScaleX="1.2" ScaleY="1.2" CenterX="16" CenterY="16"/>
                                                </CheckBox.RenderTransform>
                                            </CheckBox>
                                            <TextBlock Grid.Column="1" Text="{x:Bind Task}" Style="{StaticResource PremiumBodyStyle}" FontSize="16" VerticalAlignment="Center" Margin="16,0"/>
                                            
                                            <Button Grid.Column="2" Click="OnDeleteTask" Background="Transparent" BorderThickness="0" Padding="12" CornerRadius="8">
                                                <FontIcon Glyph="&#xE74D;" Foreground="#EF4444" FontSize="16"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- ============================================== -->
                <!-- ATHKAR VIEW                                    -->
                <!-- ============================================== -->
                <ScrollViewer x:Name="AthkarView" Visibility="Collapsed">
                    <StackPanel Spacing="40" MaxWidth="1000" HorizontalAlignment="Center">
                        <TextBlock Text="Daily Athkar" Style="{StaticResource PremiumHeaderStyle}"/>
                        
                        <Pivot>
                            <!-- Morning -->
                            <PivotItem Header="Morning">
                                <ItemsControl ItemsSource="{x:Bind AthkarVM.MorningAthkar}" Margin="0,24,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:AthkarItem">
                                            <Border Style="{StaticResource PremiumCardStyle}" Padding="40" Margin="0,0,0,24">
                                                <StackPanel Spacing="24">
                                                    <Border Background="{ThemeResource BrandAccentAlphaBrush}" CornerRadius="16" Padding="20,6" HorizontalAlignment="Left" BorderBrush="{ThemeResource BrandAccentBrush}" BorderThickness="1">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <FontIcon Glyph="&#xE8B3;" FontSize="12" Foreground="{ThemeResource BrandAccentBrush}"/>
                                                            <TextBlock Text="{x:Bind Count}" Foreground="{ThemeResource BrandAccentBrush}" FontSize="14" FontWeight="Bold"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <TextBlock Text="{x:Bind Text}" Style="{StaticResource QuranTextStyle}" FontSize="28" TextAlignment="Right" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{x:Bind Description}" Style="{StaticResource PremiumBodyStyle}" FontSize="16" Foreground="{ThemeResource TextSecondaryBrush}" TextAlignment="Right"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </PivotItem>

                            <!-- Evening -->
                            <PivotItem Header="Evening">
                                <ItemsControl ItemsSource="{x:Bind AthkarVM.EveningAthkar}" Margin="0,24,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <!-- Same Template as Morning -->
                                        <DataTemplate x:DataType="models:AthkarItem">
                                            <Border Style="{StaticResource PremiumCardStyle}" Padding="40" Margin="0,0,0,24">
                                                <StackPanel Spacing="24">
                                                    <Border Background="{ThemeResource BrandAccentAlphaBrush}" CornerRadius="16" Padding="20,6" HorizontalAlignment="Left" BorderBrush="{ThemeResource BrandAccentBrush}" BorderThickness="1">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <FontIcon Glyph="&#xE8B3;" FontSize="12" Foreground="{ThemeResource BrandAccentBrush}"/>
                                                            <TextBlock Text="{x:Bind Count}" Foreground="{ThemeResource BrandAccentBrush}" FontSize="14" FontWeight="Bold"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <TextBlock Text="{x:Bind Text}" Style="{StaticResource QuranTextStyle}" FontSize="28" TextAlignment="Right" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{x:Bind Description}" Style="{StaticResource PremiumBodyStyle}" FontSize="16" Foreground="{ThemeResource TextSecondaryBrush}" TextAlignment="Right"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </PivotItem>

                            <!-- After Prayer -->
                            <PivotItem Header="After Prayer">
                                <StackPanel Spacing="32" Margin="0,24,0,0">
                                    <ComboBox ItemsSource="{x:Bind AthkarVM.AfterPrayerFilters}" SelectedItem="{x:Bind AthkarVM.SelectedAfterPrayerFilter, Mode=TwoWay}" HorizontalAlignment="Right" Width="200" CornerRadius="8"/>
                                    <ItemsControl ItemsSource="{x:Bind AthkarVM.AfterPrayerAthkar}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:AthkarItem">
                                                <Border Style="{StaticResource PremiumCardStyle}" Padding="40" Margin="0,0,0,24">
                                                    <StackPanel Spacing="24">
                                                        <Border Background="{ThemeResource BrandAccentAlphaBrush}" CornerRadius="16" Padding="20,6" HorizontalAlignment="Left" BorderBrush="{ThemeResource BrandAccentBrush}" BorderThickness="1">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <FontIcon Glyph="&#xE8B3;" FontSize="12" Foreground="{ThemeResource BrandAccentBrush}"/>
                                                                <TextBlock Text="{x:Bind Count}" Foreground="{ThemeResource BrandAccentBrush}" FontSize="14" FontWeight="Bold"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <TextBlock Text="{x:Bind Text}" Style="{StaticResource QuranTextStyle}" FontSize="28" TextAlignment="Right" TextWrapping="Wrap"/>
                                                        <TextBlock Text="{x:Bind Description}" Style="{StaticResource PremiumBodyStyle}" FontSize="16" Foreground="{ThemeResource TextSecondaryBrush}" TextAlignment="Right"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </PivotItem>
                        </Pivot>
                    </StackPanel>
                </ScrollViewer>

                <!-- ============================================== -->
                <!-- SETTINGS VIEW                                  -->
                <!-- ============================================== -->
                <ScrollViewer x:Name="SettingsView" Visibility="Collapsed">
                    <StackPanel Spacing="48" MaxWidth="800" HorizontalAlignment="Center">
                        <TextBlock Text="Settings" Style="{StaticResource PremiumHeaderStyle}"/>
                        
                        <!-- Appearance -->
                        <Border Style="{StaticResource PremiumCardStyle}" Padding="40">
                            <StackPanel Spacing="24">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <FontIcon Glyph="&#xE790;" Foreground="{ThemeResource BrandAccentBrush}" FontSize="20"/>
                                    <TextBlock Text="Appearance" Style="{StaticResource PremiumSubheaderStyle}" FontSize="20" Foreground="{ThemeResource BrandPrimaryBrush}"/>
                                </StackPanel>
                                
                                <Grid>
                                    <TextBlock Text="Theme Mode" VerticalAlignment="Center" Style="{StaticResource PremiumBodyStyle}"/>
                                    <ComboBox SelectedIndex="{x:Bind SettingsVM.ThemeModeIndex, Mode=TwoWay}" HorizontalAlignment="Right" Width="200" CornerRadius="8">
                                        <ComboBoxItem Content="System Default"/>
                                        <ComboBoxItem Content="Light"/>
                                        <ComboBoxItem Content="Dark"/>
                                    </ComboBox>
                                </Grid>
                                <Rectangle Height="1" Fill="{ThemeResource CardBorderBrush}"/>

                                <Grid>
                                    <TextBlock Text="Language" VerticalAlignment="Center" Style="{StaticResource PremiumBodyStyle}"/>
                                    <ComboBox SelectedIndex="{x:Bind SettingsVM.LanguageIndex, Mode=TwoWay}" HorizontalAlignment="Right" Width="200" CornerRadius="8">
                                        <ComboBoxItem Content="العربية"/>
                                        <ComboBoxItem Content="English"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Prayer Times & Location -->
                        <Border Style="{StaticResource PremiumCardStyle}" Padding="40">
                            <StackPanel Spacing="24">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <FontIcon Glyph="&#xE707;" Foreground="{ThemeResource BrandAccentBrush}" FontSize="20"/>
                                    <TextBlock Text="Prayer Times &amp; Location" Style="{StaticResource PremiumSubheaderStyle}" FontSize="20" Foreground="{ThemeResource BrandPrimaryBrush}"/>
                                </StackPanel>
                                
                                <Grid>
                                    <TextBlock Text="Auto-detect Location" VerticalAlignment="Center" Style="{StaticResource PremiumBodyStyle}"/>
                                    <ToggleSwitch IsOn="{x:Bind SettingsVM.AutoDetectLocation, Mode=TwoWay}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Rectangle Height="1" Fill="{ThemeResource CardBorderBrush}"/>

                                <Grid>
                                    <TextBlock Text="Calculation Method" VerticalAlignment="Center" Style="{StaticResource PremiumBodyStyle}"/>
                                    <ComboBox SelectedIndex="{x:Bind SettingsVM.CalculationMethodIndex, Mode=TwoWay}" HorizontalAlignment="Right" Width="250" CornerRadius="8">
                                        <ComboBoxItem Content="Muslim World League"/>
                                        <ComboBoxItem Content="Islamic Society of North America"/>
                                        <ComboBoxItem Content="Egyptian General Authority"/>
                                        <ComboBoxItem Content="Umm Al-Qura, Makkah"/>
                                        <ComboBoxItem Content="University of Islamic Sciences, Karachi"/>
                                        <ComboBoxItem Content="Institute of Geophysics, University of Tehran"/>
                                        <ComboBoxItem Content="Gulf Region"/>
                                        <ComboBoxItem Content="Kuwait"/>
                                        <ComboBoxItem Content="Qatar"/>
                                        <ComboBoxItem Content="Majlis Ugama Islam Singapura, Singapore"/>
                                    </ComboBox>
                                </Grid>
                                <Rectangle Height="1" Fill="{ThemeResource CardBorderBrush}"/>

                                <Grid>
                                    <TextBlock Text="Asr Calculation (Madhab)" VerticalAlignment="Center" Style="{StaticResource PremiumBodyStyle}"/>
                                    <ComboBox SelectedIndex="{x:Bind SettingsVM.MadhabIndex, Mode=TwoWay}" HorizontalAlignment="Right" Width="250" CornerRadius="8">
                                        <ComboBoxItem Content="Standard (Shafi, Hanbali, Maliki)"/>
                                        <ComboBoxItem Content="Hanafi"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Notifications -->
                        <Border Style="{StaticResource PremiumCardStyle}" Padding="40">
                            <StackPanel Spacing="24">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <FontIcon Glyph="&#xEA8F;" Foreground="{ThemeResource BrandAccentBrush}" FontSize="20"/>
                                    <TextBlock Text="Notifications &amp; Audio" Style="{StaticResource PremiumSubheaderStyle}" FontSize="20" Foreground="{ThemeResource BrandPrimaryBrush}"/>
                                </StackPanel>
                                
                                <Grid>
                                    <TextBlock Text="Adhan Volume" VerticalAlignment="Center" Style="{StaticResource PremiumBodyStyle}"/>
                                    <Slider Value="{x:Bind SettingsVM.Volume, Mode=TwoWay}" Minimum="0" Maximum="100" HorizontalAlignment="Right" Width="200"/>
                                </Grid>
                                <Rectangle Height="1" Fill="{ThemeResource CardBorderBrush}"/>
                                
                                <TextBlock Text="Enable notifications for:" Style="{StaticResource PremiumBodyStyle}" Foreground="{ThemeResource TextSecondaryBrush}"/>
                                
                                <VariableSizedWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="3" ItemWidth="150" ItemHeight="40">
                                    <CheckBox Content="Fajr" IsChecked="{x:Bind SettingsVM.FajrEnabled, Mode=TwoWay}"/>
                                    <CheckBox Content="Dhuhr" IsChecked="{x:Bind SettingsVM.DhuhrEnabled, Mode=TwoWay}"/>
                                    <CheckBox Content="Asr" IsChecked="{x:Bind SettingsVM.AsrEnabled, Mode=TwoWay}"/>
                                    <CheckBox Content="Maghrib" IsChecked="{x:Bind SettingsVM.MaghribEnabled, Mode=TwoWay}"/>
                                    <CheckBox Content="Isha" IsChecked="{x:Bind SettingsVM.IshaEnabled, Mode=TwoWay}"/>
                                </VariableSizedWrapGrid>
                            </StackPanel>
                        </Border>

                        <!-- General & App Behavior -->
                        <Border Style="{StaticResource PremiumCardStyle}" Padding="40">
                            <StackPanel Spacing="24">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <FontIcon Glyph="&#xE713;" Foreground="{ThemeResource BrandAccentBrush}" FontSize="20"/>
                                    <TextBlock Text="General" Style="{StaticResource PremiumSubheaderStyle}" FontSize="20" Foreground="{ThemeResource BrandPrimaryBrush}"/>
                                </StackPanel>
                                
                                <Grid>
                                    <TextBlock Text="Start Zakarni on Windows Startup" VerticalAlignment="Center" Style="{StaticResource PremiumBodyStyle}"/>
                                    <ToggleSwitch IsOn="{x:Bind SettingsVM.RunAtStartup, Mode=TwoWay}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Rectangle Height="1" Fill="{ThemeResource CardBorderBrush}"/>

                                <Grid>
                                    <TextBlock Text="Minimize to Tray when closed" VerticalAlignment="Center" Style="{StaticResource PremiumBodyStyle}"/>
                                    <ToggleSwitch IsOn="{x:Bind SettingsVM.MinimizeToTray, Mode=TwoWay}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Rectangle Height="1" Fill="{ThemeResource CardBorderBrush}"/>

                                <Grid>
                                    <TextBlock Text="Keep Floating Widget Always on Top" VerticalAlignment="Center" Style="{StaticResource PremiumBodyStyle}"/>
                                    <ToggleSwitch IsOn="{x:Bind SettingsVM.KeepFloatingWidgetAlwaysOnTop, Mode=TwoWay}" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Actions -->
                        <Grid Margin="0,16,0,0">
                            <Button Content="Reset to Defaults" Command="{x:Bind SettingsVM.ResetToDefaultsCommand}" Style="{StaticResource SubtleButtonStyle}" Foreground="#EF4444" HorizontalAlignment="Left" Padding="24,12"/>
                            <Button Content="Save &amp; Apply Changes" Click="OnSaveSettings" Style="{StaticResource PremiumAccentButtonStyle}" HorizontalAlignment="Right" Padding="48,16" CornerRadius="12"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </NavigationView>
    </Grid>
</Window>