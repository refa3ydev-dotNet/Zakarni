<Window
    x:Class="Zakarni.UI.QuranReadingWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Zakarni.Core.Models"
    Title="Mushaf Al-Zakarni">

    <!-- The root container has NO size constraints to avoid clipping -->
    <Grid Background="{ThemeResource SurfaceBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <!-- Tafsir Side Panel Column -->
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Header Bar -->
        <Border Grid.ColumnSpan="2" Background="{ThemeResource SurfaceCardBackground}" Padding="32,24" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Button Click="OnClose" Style="{StaticResource SubtleButtonStyle}" HorizontalAlignment="Left">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE711;" FontSize="14" Foreground="{ThemeResource TextSecondaryBrush}"/>
                            <TextBlock Text="Return to Dashboard" Style="{StaticResource PremiumBodyStyle}" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button.Content>
                </Button>

                <!-- Centered Surah Name -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16">
                    <TextBlock x:Name="SurahNameTitle" Style="{StaticResource PremiumHeaderStyle}" FontSize="28" Foreground="{ThemeResource BrandPrimaryBrush}"/>
                </StackPanel>

                <!-- Actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <TextBlock x:Name="SurahInfoText" Style="{StaticResource PremiumBodyStyle}" Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,24,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Reading Area (Continuous Flow) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>

            <!-- Navigation Buttons -->
            <Button Grid.Column="0" Click="OnPrevSurah" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Style="{StaticResource SubtleButtonStyle}" Opacity="0.3" ToolTipService.ToolTip="Previous Surah">
                <FontIcon Glyph="&#xE760;" FontSize="24"/>
            </Button>

            <!-- The Scrollable Content -->
            <ScrollViewer x:Name="MainScrollViewer" Grid.Column="1" Padding="24,40" VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="1000" HorizontalAlignment="Stretch" Spacing="32">
                    
                    <TextBlock x:Name="ErrorText" Foreground="Red" FontSize="16" HorizontalAlignment="Center" Visibility="Collapsed"/>

                    <!-- Continuous flowing text is dynamically populated here as multiple blocks to prevent size limits -->
                    <Border Background="Transparent" Padding="48,24" HorizontalAlignment="Stretch">
                        <StackPanel x:Name="SurahContentPanel" HorizontalAlignment="Stretch" Spacing="0"/>
                    </Border>
                    
                </StackPanel>
            </ScrollViewer>

            <Button Grid.Column="2" Click="OnNextSurah" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Style="{StaticResource SubtleButtonStyle}" Opacity="0.3" ToolTipService.ToolTip="Next Surah">
                <FontIcon Glyph="&#xE761;" FontSize="24"/>
            </Button>
            
            <!-- Loading Overlay -->
            <Grid Grid.ColumnSpan="3" Background="{ThemeResource SurfaceBackground}" Opacity="0.95" Visibility="{x:Bind ViewModel.IsLoadingSurah, Mode=OneWay}" Canvas.ZIndex="10">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24">
                    <ProgressRing IsActive="{x:Bind ViewModel.IsLoadingSurah, Mode=OneWay}" Width="64" Height="64" Foreground="{ThemeResource BrandPrimaryBrush}"/>
                    <TextBlock Text="Loading Surah..." Style="{StaticResource PremiumSubheaderStyle}" FontSize="20" Foreground="{ThemeResource BrandPrimaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Elegant Tafsir Side Panel -->
        <Border Grid.Row="1" Grid.Column="1" Width="400" Background="{ThemeResource SurfaceCardBackground}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1,0,0,0" Padding="32" Visibility="{x:Bind ViewModel.IsSidePanelOpen, Mode=OneWay}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Spacing="8">
                    <Grid>
                        <TextBlock Text="Ayah Details" Style="{StaticResource PremiumHeaderStyle}" FontSize="20"/>
                        <Button Click="OnCloseSidePanel" Style="{StaticResource SubtleButtonStyle}" HorizontalAlignment="Right" Width="32" Height="32" Padding="0" CornerRadius="16">
                            <FontIcon Glyph="&#xE711;" FontSize="12"/>
                        </Button>
                    </Grid>
                    
                    <Border Background="{ThemeResource BrandAccentAlphaBrush}" CornerRadius="12" Padding="16,8" HorizontalAlignment="Left" Margin="0,16,0,0">
                        <TextBlock Text="{x:Bind ViewModel.ActiveAyah.SurahNameAr, Mode=OneWay}" Style="{StaticResource PremiumBodyStyle}" FontWeight="Bold" Foreground="{ThemeResource BrandAccentBrush}"/>
                    </Border>
                    <TextBlock Text="{x:Bind ViewModel.ActiveAyah.NumberInSurah, Mode=OneWay}" FontSize="14" Opacity="0.6" Margin="0,-4,0,0"/>
                </StackPanel>

                <!-- Translation Content -->
                <ScrollViewer Grid.Row="1" Margin="0,24">
                    <StackPanel Spacing="16">
                        <TextBlock Text="{x:Bind ViewModel.ActiveAyah.Text, Mode=OneWay}" Style="{StaticResource QuranTextStyle}" FontSize="24" TextAlignment="Right" LineHeight="40"/>
                        <Rectangle Height="1" Fill="{ThemeResource CardBorderBrush}" Margin="0,8"/>
                        
                        <TextBlock Text="English Translation" Style="{StaticResource PremiumSubheaderStyle}" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource BrandPrimaryBrush}"/>
                        <TextBlock Text="{x:Bind ViewModel.ActiveAyah.Translation, Mode=OneWay}" Style="{StaticResource PremiumBodyStyle}" LineHeight="28" TextWrapping="Wrap" Opacity="0.9"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Audio Actions -->
                <Button Grid.Row="2" Click="OnPlayActiveAyah" Style="{StaticResource PremiumAccentButtonStyle}" HorizontalAlignment="Stretch">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE768;" FontSize="16"/>
                            <TextBlock Text="Play Ayah Audio"/>
                        </StackPanel>
                    </Button.Content>
                </Button>
            </Grid>
        </Border>

        <!-- Bottom Audio Player Bar -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="{ThemeResource SurfaceCardBackground}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="0,1,0,0" Padding="32,20" x:Name="PlayerBar">
            <Grid MaxWidth="1200" HorizontalAlignment="Center" Width="1000">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="24" VerticalAlignment="Center">
                    <Button x:Name="PlayPauseButton" Click="OnPlayPauseToggle" Style="{StaticResource PremiumAccentButtonStyle}" Width="56" Height="56" CornerRadius="28" Padding="0">
                        <FontIcon x:Name="PlayPauseIcon" Glyph="&#xE768;" FontSize="24"/>
                    </Button>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Mishary Rashid Alafasy" Style="{StaticResource PremiumBodyStyle}" FontWeight="Bold" FontSize="16"/>
                        <TextBlock x:Name="NowPlayingText" Text="Select an Ayah to begin recitation" FontSize="14" Foreground="{ThemeResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                     <!-- Additional audio controls can go here, like stop, loop, etc. -->
                     <Button Click="OnStopAudio" Style="{StaticResource SubtleButtonStyle}" ToolTipService.ToolTip="Stop Audio">
                         <FontIcon Glyph="&#xE71A;" FontSize="20"/>
                     </Button>
                </StackPanel>

                <!-- Hidden MediaPlayerElement for Audio Stream -->
                <MediaPlayerElement x:Name="AudioPlayer" AutoPlay="False" AreTransportControlsEnabled="False" Visibility="Collapsed"/>
            </Grid>
        </Border>

    </Grid>
</Window>